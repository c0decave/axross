FROM debian:bookworm-slim

ARG USERNAME=rsyncuser
ARG PASSWORD=rsync123

RUN apt-get update && \
    apt-get install -y --no-install-recommends rsync && \
    rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash ${USERNAME} && \
    echo "${USERNAME}:${PASSWORD}" | chpasswd

COPY rsyncd.conf /etc/rsyncd.conf

RUN echo "${USERNAME}:${PASSWORD}" > /etc/rsyncd.secrets && \
    chmod 600 /etc/rsyncd.secrets

RUN mkdir -p /srv/rsync/testmod && \
    echo "rsync test file" > /srv/rsync/testmod/readme.txt && \
    mkdir -p /srv/rsync/testmod/subdir && \
    echo "nested file" > /srv/rsync/testmod/subdir/nested.txt && \
    chown -R ${USERNAME}:${USERNAME} /srv/rsync

EXPOSE 873

CMD ["rsync", "--daemon", "--no-detach", "--log-file=/dev/stdout"]
