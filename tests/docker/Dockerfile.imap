FROM debian:bookworm-slim

ARG USERNAME=imapuser
ARG PASSWORD=imap123

RUN apt-get update && \
    apt-get install -y --no-install-recommends dovecot-imapd && \
    rm -rf /var/lib/apt/lists/*

# Create the test user
RUN useradd -m -s /bin/bash ${USERNAME} && \
    echo "${USERNAME}:${PASSWORD}" | chpasswd

# Configure Dovecot for plaintext IMAP (no SSL) on port 143
RUN sed -i 's/^#*\s*disable_plaintext_auth\s*=.*/disable_plaintext_auth = no/' /etc/dovecot/conf.d/10-auth.conf && \
    sed -i 's/^#*\s*auth_mechanisms\s*=.*/auth_mechanisms = plain login/' /etc/dovecot/conf.d/10-auth.conf && \
    sed -i 's|^#*\s*mail_location\s*=.*|mail_location = maildir:~/Maildir|' /etc/dovecot/conf.d/10-mail.conf && \
    echo 'listen = *' >> /etc/dovecot/dovecot.conf && \
    echo 'ssl = no' > /etc/dovecot/conf.d/10-ssl-override.conf

# Create initial Maildir structure and seed a test email
RUN mkdir -p /home/${USERNAME}/Maildir/new \
             /home/${USERNAME}/Maildir/cur \
             /home/${USERNAME}/Maildir/tmp \
             /home/${USERNAME}/Maildir/.Sent/new \
             /home/${USERNAME}/Maildir/.Sent/cur \
             /home/${USERNAME}/Maildir/.Sent/tmp && \
    printf 'From: test@example.com\r\nTo: %s@localhost\r\nSubject: Welcome\r\nDate: Sat, 01 Jan 2025 00:00:00 +0000\r\nMessage-ID: <seed001@example.com>\r\n\r\nHello from IMAP\r\n' "${USERNAME}" \
        > /home/${USERNAME}/Maildir/new/seed001.eml && \
    chown -R ${USERNAME}:${USERNAME} /home/${USERNAME}/Maildir

EXPOSE 143

CMD ["dovecot", "-F"]
