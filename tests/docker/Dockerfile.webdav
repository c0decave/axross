FROM debian:bookworm-slim

ARG USERNAME=davuser
ARG PASSWORD=dav123

RUN apt-get update && \
    apt-get install -y --no-install-recommends apache2 apache2-utils && \
    rm -rf /var/lib/apt/lists/* && \
    a2enmod dav dav_fs auth_basic authn_file && \
    mkdir -p /var/www/webdav/subdir /var/www/webdav/emptydir && \
    echo "Hello from WebDAV" > /var/www/webdav/readme.txt && \
    echo "nested file" > /var/www/webdav/subdir/nested.txt && \
    dd if=/dev/urandom of=/var/www/webdav/bigfile.bin bs=1k count=64 2>/dev/null && \
    chown -R www-data:www-data /var/www/webdav && \
    htpasswd -cb /etc/apache2/.htpasswd ${USERNAME} ${PASSWORD} && \
    mkdir -p /var/lib/dav && chown www-data:www-data /var/lib/dav

COPY webdav-vhost.conf /etc/apache2/sites-available/000-default.conf

EXPOSE 80
CMD ["apachectl", "-D", "FOREGROUND"]
